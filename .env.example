DATABASE_URL=sqlite+aiosqlite:///./dev.db
SARVAM_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
LLM_PROVIDER=sarvam
HOST=0.0.0.0
DEBUG=true

# CORS — comma-separated origins. Set to your frontend URL on Railway.
ALLOWED_ORIGINS=http://localhost:3000

# M1 — path to cookies.txt exported from your browser (gitignored).
# Local only. On Railway leave unset and use YT_PROXY instead.
YTDLP_COOKIES_FILE=C:\Users\kawin\Projects\omi-ted-v2\cookies.txt

# Cloud transcript fetching — rotating proxy for YouTube rate limits.
# Get one at webshare.io ($1/mo). Set on Railway backend service.
YT_PROXY=
YT_MAX_RETRIES=4
YT_BASE_BACKOFF=2.0
