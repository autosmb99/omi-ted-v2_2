# Copy this to .env.local and fill in values.
# .env.local is gitignored — never commit it.

# Local development: next.config.js rewrites /api/* → http://localhost:8000/api/*
# You don't normally need to set BACKEND_URL locally unless you've changed the port.
BACKEND_URL=http://localhost:8000

# Exposed to the browser — safe to set but currently unused (all calls go through the proxy).
NEXT_PUBLIC_API_BASE=http://localhost:8000
