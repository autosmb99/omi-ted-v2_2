# OMI-TED v2 — Backend environment variables
# Copy this to backend/.env and fill in real values.
# Never commit the real .env to git.

# Sarvam AI translation (https://www.sarvam.ai — free tier available)
# Get your key at: https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_key_here

# Google Cloud Translation v2 (alternative provider)
# GOOGLE_API_KEY=your_google_key_here

# OpenRouter (alternative provider — supports many models)
# OPENROUTER_API_KEY=your_openrouter_key_here
